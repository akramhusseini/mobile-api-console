{
  "manifest_version": 3,
  "name": "Mobile API Console",
  "version": "0.1.0",
  "description": "Mirror fetch / XMLHttpRequest traffic from chosen tabs to a local Mobile API Console. Loads only after you grant target page and request URL permissions from the Options page.",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage",
    "webRequest",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["page-inject.js"],
      "run_at": "document_start",
      "all_frames": false,
      "match_about_blank": false,
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mobile API Console — capture this site"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
